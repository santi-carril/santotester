<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SANTITESTER | SMART LOCK PRO</title>
    <style>
        :root {
            --bg: #0a0c10;
            --sidebar: #12151a;
            --border: #30363d;
            --accent: #f2a154; /* Safety Orange for Hardware Pro Tools */
            --text: #e6edf3;
            --pro-blue: #58a6ff;
            --danger: #ff7b72;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: 'Segoe UI', system-ui, sans-serif;
            margin: 0;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* DISCLAIMER OVERLAY */
        #pro-lock {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(5px);
        }

        .disclaimer-card {
            background: var(--sidebar);
            padding: 30px;
            border: 2px solid var(--accent);
            border-radius: 12px;
            width: 400px;
            text-align: center;
        }

        /* APP LAYOUT */
        #explorer {
            width: 320px;
            background-color: var(--sidebar);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
        }

        .header {
            padding: 20px;
            background: #1a1f26;
            border-bottom: 1px solid var(--border);
        }

        .status-badge {
            font-size: 10px;
            background: var(--accent);
            color: black;
            padding: 2px 6px;
            border-radius: 4px;
            font-weight: bold;
        }

        #file-list {
            flex: 1;
            overflow-y: auto;
            padding: 10px;
        }

        .test-file {
            padding: 12px;
            margin-bottom: 5px;
            background: #0d1117;
            border: 1px solid #21262d;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
            transition: 0.2s;
        }

        .test-file:hover { border-color: var(--pro-blue); }

        /* DIAGNOSTIC PANEL */
        #main-stage {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .diagnostic-header {
            padding: 15px 25px;
            background: #161b22;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .code-view {
            flex: 1;
            padding: 0;
            background: #000;
            overflow: auto;
        }

        pre {
            margin: 0;
            padding: 20px;
            font-family: 'Consolas', monospace;
            color: #d1d5db;
            line-height: 1.5;
        }

        .btn-action {
            background: var(--accent);
            color: black;
            border: none;
            padding: 10px;
            border-radius: 6px;
            font-weight: bold;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <div id="pro-lock">
        <div class="disclaimer-card">
            <h2 style="color:var(--accent)">PRO ACCESS ONLY</h2>
            <p style="font-size: 14px; line-height: 1.6;">
                <strong>SANTITESTER v2.0</strong><br>
                Smart Lock Compatibility Test Environment.<br><br>
                This app is strictly for use by authorized professionals. T&Cs apply.
            </p>
            <button class="btn-action" style="width:100%" onclick="unlockApp()">I AM A PROFESSIONAL</button>
        </div>
    </div>

    <div id="explorer">
        <div class="header">
            <div style="font-weight:bold; margin-bottom:5px;">SANTITESTER <span class="status-badge">PRO</span></div>
            <div style="font-size:11px; color:#8b949e;">santi-carril / santotester</div>
        </div>
        <div id="file-list">
            <div style="text-align:center; padding:20px; color:#555;">Initializing diagnostic scripts...</div>
        </div>
        <div style="padding:15px;">
            <button onclick="fetchHardwareTests()" class="btn-action" style="width:100%; background:#238636; color:white;">LOAD TEST SUITE</button>
        </div>
    </div>

    <div id="main-stage">
        <div class="diagnostic-header">
            <div id="active-file">System Ready</div>
            <div style="font-size:12px; color:var(--accent)">HARDWARE_LINK: PENDING</div>
        </div>
        <div class="code-view">
            <pre id="diagnostic-output">// Please select a compatibility test script from the sidebar...</pre>
        </div>
    </div>

<script>
    function unlockApp() {
        document.getElementById('pro-lock').style.display = 'none';
    }

    async function fetchHardwareTests() {
        const list = document.getElementById('file-list');
        list.innerHTML = "<div style='color:var(--pro-blue); padding:10px;'>Contacting GitHub...</div>";
        
        try {
            const response = await fetch('https://api.github.com/repos/santi-carril/santotester/contents/');
            const files = await response.json();

            list.innerHTML = "";
            files.forEach(file => {
                if(file.type === 'file') {
                    const div = document.createElement('div');
                    div.className = 'test-file';
                    div.innerHTML = `<strong>TEST:</strong> ${file.name}`;
                    div.onclick = () => ripDiagnostic(file.download_url, file.name);
                    list.appendChild(div);
                }
            });
        } catch (err) {
            list.innerHTML = "<div style='color:var(--danger)'>ERR: REPO_LINK_FAILED</div>";
        }
    }

    async function ripDiagnostic(url, name) {
        const output = document.getElementById('diagnostic-output');
        const label = document.getElementById('active-file');
        
        label.innerText = "Active Test: " + name;
        output.innerText = "// Ripping Hardware Parameters...";

        try {
            const res = await fetch(url);
            const content = await res.text();
            output.innerText = content;
        } catch (err) {
            output.innerText = "CRITICAL: FAILED TO PULL SCRIPT DATA";
        }
    }
</script>
</body>
</html>
